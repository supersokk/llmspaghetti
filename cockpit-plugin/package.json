{
  "name": "llmspaghetti-cockpit-plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "watch": "webpack --config webpack.config.js --watch",
    "install-plugin": "npm run build && sudo cp -r dist/ /usr/share/cockpit/llmspaghetti/ && sudo cp manifest.json /usr/share/cockpit/llmspaghetti/ && sudo cp index.html /usr/share/cockpit/llmspaghetti/"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "babel-loader": "^9.1.3",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
