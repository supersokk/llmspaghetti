# =============================================================================
# LLMOS .gitignore
# =============================================================================

# ── Node / Cockpit plugin build ───────────────────────────────────────────────
cockpit-plugin/node_modules/
cockpit-plugin/dist/

# ── VS Code extension build ───────────────────────────────────────────────────
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/*.vsix

# ── ISO / release build artifacts ────────────────────────────────────────────
iso/cache/
*.iso
llmos-*.tar.gz
llmspaghetti*.tar.gz

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# ── Secrets / local config ────────────────────────────────────────────────────
.env
.env.local
*.key
config/master_key
config/api_keys.env
config/litellm_config.yaml.local

# ── Runtime / install artifacts ───────────────────────────────────────────────
/opt/
*.log
logs/

# ── Routing flywheel — local data (never commit) ──────────────────────────────
# overrides_local.jsonl contains user corrections — personal, stays on machine
**/overrides_local.jsonl
**/corrections_export.jsonl
# fixtures_base.jsonl IS committed — it ships with the release
# community/fixtures/contributed/*.jsonl ARE committed — they're contributions

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
