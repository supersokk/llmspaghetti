# =============================================================================
# LLMSpaghetti Environment Variables
# Copy to .env and fill in your values, OR export before running bootstrap.sh
#
# Usage:
#   export ANTHROPIC_API_KEY=sk-ant-...
#   sudo -E bash scripts/bootstrap.sh
#
# None of these are required — they can all be set later via the web UI
# (LLMSpaghetti → API Gateway tab, or: spag config)
# =============================================================================

# ── Cloud API keys (all optional) ────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Install config (optional overrides) ──────────────────────────────────────
LLMSPAGHETTI_USER=llmspaghetti
INSTALL_DIR=/opt/llmspaghetti
WEBUI_PORT=3000
LITELLM_PORT=4000

# ── Domain (optional — leave blank for IP-only / local network use) ───────────
# Set this if you have a domain pointing at this machine.
# Caddy will automatically obtain a Let's Encrypt TLS certificate.
CADDY_DOMAIN=
