# =============================================================================
# LLMSpaghetti Caddyfile
# Generated by bootstrap.sh — edit with: sudo nano /etc/caddy/Caddyfile
#                              then:      sudo systemctl reload caddy
# =============================================================================

# ── Main interface (port 80, or domain with auto-HTTPS) ──────────────────────
:80 {

    # ── Security headers ────────────────────────────────────────────────────
    header {
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "SAMEORIGIN"
        Referrer-Policy           "strict-origin-when-cross-origin"
        # Allow terminal iframe to work within LLMSpaghetti UI (same origin)
        Content-Security-Policy   "default-src 'self' 'unsafe-inline' 'unsafe-eval' ws: wss: blob: data:;"
        -Server
    }

    # ── Web terminal (ttyd) ─────────────────────────────────────────────────
    # Proxied at /terminal/ so it lives inside the main UI
    # WebSocket upgrade is essential for ttyd to function
    handle /terminal/* {
        uri strip_prefix /terminal
        reverse_proxy localhost:7681 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            # WebSocket support
            header_up Upgrade {http.request.header.Upgrade}
            header_up Connection {http.request.header.Connection}
        }
    }

    # ── Generated images (served by router) ────────────────────────────────
    handle /images/* {
        reverse_proxy localhost:5000 {
            header_up Host {host}
        }
    }

    # ── External OpenAI-compatible API (via router) ──────────────────────────
    # External tools (Cursor, Continue.dev, Aider, VS Code) point here.
    # /v1/* goes to the router which classifies and routes to the right model.
    # Using /v1/ avoids conflict with Open WebUI's own /api/ paths.
    handle /v1/* {
        reverse_proxy localhost:5000 {
            header_up Host {host}
            request_buffers 64MB
        }
    }

    # ── SpagDesk (native workspace — Phase 0/1 MVP, static/buildless) ────────
    # Served at /desk/ ; its router calls go through /spag/* (below) so they
    # don't collide with Open WebUI's own /api/*. See docs/PLANNED-spagdesk.md.
    handle /desk/* {
        uri strip_prefix /desk
        root * /opt/llmspaghetti/spagdesk
        file_server
    }

    # SpagDesk → router (chat /v1 + management /api) under one clean prefix.
    handle /spag/* {
        uri strip_prefix /spag
        reverse_proxy localhost:5000 {
            header_up Host {host}
            request_buffers 64MB
        }
    }

    # ── SpagDesk (default client — served at root) ──────────────────────────
    # SpagDesk is the primary workspace, so the bare IP lands here. Its router
    # calls use absolute /spag/* + /images/* (above), so serving it at / behaves
    # exactly like /desk/. Open WebUI is optional now — install it from the
    # Cockpit Services tab (it then runs on :3000).
    handle /* {
        root * /opt/llmspaghetti/spagdesk
        try_files {path} /index.html
        file_server
    }

    # ── Logging ─────────────────────────────────────────────────────────────
    encode gzip
    log {
        output file /var/log/caddy/llmspaghetti.log {
            roll_size     50MB
            roll_keep     5
            roll_keep_for 720h
        }
        format json
    }
}

# ── Cockpit (port 9090) ───────────────────────────────────────────────────────
# Cockpit manages its own TLS and auth — we just leave port 9090 open.
# No proxy needed. Cockpit's built-in terminal is accessible at:
#   http://your-server:9090/system/terminal
